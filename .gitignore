# Large sim outputs are regenerable on VMs, not committed.
# Plot-ready CSVs under results/v<version>_baseline/ ARE committed.
raw_results/
results/raw_v*/
results/v*/*.obj
results/v*/*.pkl
results/v*/*.sim
results/v*/*.msim

# Top-level results/ is a transient VM-run scratch area.
# Freeze plot-ready snapshots under results/v<version>_baseline/ instead.
results/*.obj
results/*.pkl
results/*.sim
results/*.msim
results/*.csv

# Archives
results/*.zip
*.zip

# Local artifacts
figures/

# Manuscript (tracked separately)
*.docx
*.docx.md

# Python
__pycache__/
*.py[cod]
.DS_Store
